/* overlay should also work with inlining */

inline fn overlay_f () -> reg u32 {
  #[overlay = myoverlay] stack u32[1] s;
  reg u32 i;
  reg u32 z = 0;
  s[0] = z;
  i = s[0];
  return i;
}

#[stacksize = 20]
export fn overlay () -> reg u32 {
  #[overlay = myoverlay] stack u32[5] s2;
  reg u32 i;
  i = overlay_f();
  reg u32 z = 0;
  s2[0] = z; s2[4] = z;
  z = s2[0];
  i += z;
  return i;
}