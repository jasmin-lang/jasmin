param int n = 2;
u64 y = 5;

module M1
 with
  param int n;
{ 
 param int nn = n;
 u64 z = 3;
 fn f(reg ptr u64[5] a) -> reg ptr u64[5]
 { 
  a[nn] = 1; 
  return a; 
 }

}

module M2
 with
  param int n;
  fn i(u64) -> u64;
{
  module B = M1(n*2);
  fn ff(reg ptr u64[5] a) -> reg ptr u64[5] {
    a = B::f(a);
    a[0] = i(a[0]);
    return a;
  }

  fn nn(reg u64 n) -> reg u64 {
    n = 2;
    return n;
  }

}

module I {
u64 b = 5;
fn inc(reg u64 x) -> reg u64 {
  x += 1;
  return x;
}

fn inc2(reg u64 x) -> reg u64 {
  x += 1;
  return x;
}
}

module A2 = M2(n,I::inc);
module A4 = M2(2,I::inc2);

fn inc1(reg u64 i1) -> reg u64 {
  reg u64 i2;
  i2 = A2::nn(i1);
  return i2;
}


fn inc2(reg u64 i2) -> reg u64 {
 reg u64[2] a;
  a[0] = i2;
  a[1] = A2::B::z;
  i2 = I::inc(i2);
  i2 += I::b;
  return i2;
}