param int n = 2;
u64 y = 5;

module M1
 with
  param int n;
{ 
 param int nn = n;
 fn f(reg ptr u64[5] a) -> reg ptr u64[5]
 { 
  a[nn] = 1; 
  return a; 
 }

}

module M2
 with
  param int n;
  global u64 x;
{
  module B = M1(n*2);
  fn ff(reg ptr u64[5] a) -> reg ptr u64[5] {
    a = B::f(a);
    a[0] = x;
    return a;
  }
}

module A2 = M2(n,y);
module A3 = M2(n,y);
module A4 = M1(2*n);