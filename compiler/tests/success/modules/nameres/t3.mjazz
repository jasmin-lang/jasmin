param int n = 2;

module M1
 with
  param int n;
{
  param int nn = n;
  fn f(reg ptr u64[n] a) -> reg ptr u64[n]
  { return a; }

}

module M2
  with
   param int c;
{
   module B = M1(2*c);
   fn ff(reg ptr u64[2*c] a) -> reg ptr u64[2*c] {
     a = B::f(a);
     return a;
   }
}

module A2 = M2(n);
module A4 = M1(2*n);
module B4 = M2(4);
