#[required_alignment = { p = u128 }]
export fn aes_test (reg ptr u128[1] p) -> reg ptr u128[1] {
reg u128 x1 x2, x3;

x1 = #set0_128();
x2 = #set0_128();

x1 = #AESENC(x1, x2);
x1 = #AESENC(x1, p[#aligned 0]);
p[0] = x1;
x3 = #VAESENC(x1, x2);
p[0] = x3;
x3 = #VAESENC(x1, p[0]);
p[0] = x3;

x1 = #AESDEC(x1, x2);
x1 = #AESDEC(x1, p[#aligned 0]);
p[0] = x1;
x3 = #VAESDEC(x1, x2);
p[0] = x3;
x3 = #VAESDEC(x1, p[0]);
p[0] = x3;

x1 = #AESIMC(x1);
x1 = #VAESIMC(x1);
p[0] = x1;
x1 = #AESIMC(p[#aligned 0]);
p[0] = x1;
x1 = #VAESIMC(p[0]);
p[0] = x1;

x3 = #AESKEYGENASSIST(x1,5);
x3 = #AESKEYGENASSIST(x3,4);
p[0] = x3;
x1 = #AESKEYGENASSIST(p[#aligned 0], 3);
p[0] = x1;

x3 = #VAESKEYGENASSIST(x1,1);
x3 = #VAESKEYGENASSIST(x3,2);
p[0] = x3;
x1 = #VAESKEYGENASSIST(p[0], 0);
p[0] = x1;

return p;
}

export
fn test_vaes(reg u64 p) {
  reg u256 x y z;
  x = [:u256 p];
  y = #VAESENC_256(x, [:u256 p + 32]);
  z = #VAESENC_256(y, x);
  x = #VAESENCLAST_256(z, [:u256 p + 64]);
  y = #VAESENCLAST_256(x, y);
  z = #VAESDEC_256(y, [:u256 p + 32]);
  x = #VAESDEC_256(z, y);
  y = #VAESDECLAST_256(x, [:u256 p]);
  z = #VAESDECLAST_256(y, x);
  [:u256 p] = z;
}
