require import AllCore IntDiv CoreMap List Distr.

from Jasmin require import JModel_x86.

import SLH64.

module M = {
  proc __for_nest () : unit = {
    var inc:int;
    var inc_0:int;
    var j:int;
    var i:int;
    inc <- (10 + 10);
    i <- 0;
    while ((i < inc)) {
      inc_0 <- (10 * 10);
      j <- 0;
      while ((j < inc_0)) {
        j <- (j + 1);
      }
      i <- (i + 1);
    }
    return ();
  }
}.
